# Copy to .env for local dev (optional). On Vercel, set these in Project Settings.

# Secret used to sign login tokens. Set a long random string in production.
AUTH_SECRET=please-change-this-to-a-long-random-string

# --- Storage (production) -------------------------------------------------
# When deploying to Vercel, click "Storage" -> connect an Upstash Redis / KV
# store. Vercel injects these automatically; you usually don't set them by hand.
# Without them, the app uses a local JSON file (data/db.json) which is fine for
# local development but NOT persisted on Vercel.
#
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# or (Upstash native names):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
